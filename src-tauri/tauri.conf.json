{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flock",
  "version": "0.1.0",
  "identifier": "dev.yani.flock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Flock",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "decorations": true,
        "trafficLightPosition": { "x": 12, "y": 14 }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "resources": {
      "../mcp/flock-mcp.mjs": "mcp/flock-mcp.mjs",
      "../mcp/package.json": "mcp/package.json",
      "../mcp/package-lock.json": "mcp/package-lock.json"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
